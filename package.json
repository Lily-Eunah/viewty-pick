{
  "name": "temp-next",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "typecheck": "tsc --noEmit",
    "cf:build": "opennextjs-cloudflare build",
    "cf:preview": "opennextjs-cloudflare build && opennextjs-cloudflare preview",
    "cf:deploy": "opennextjs-cloudflare build && opennextjs-cloudflare deploy",
    "cf:typegen": "wrangler types --env-interface CloudflareEnv cloudflare-env.d.ts",
    "sheets:headers": "tsx -r dotenv/config crawler/sheets/setup_headers.ts",
    "sheets:reseed": "tsx -r dotenv/config crawler/sheets/reseed_sheets.ts",
    "sheets:import": "tsx -r dotenv/config crawler/sheets/import.ts",
    "sheets:migrate-dropdowns-brand": "tsx -r dotenv/config scripts/ops/migrate-sheet-dropdowns-brand.ts",
    "ops:audit": "tsx -r dotenv/config scripts/ops/audit-phase-a.ts",
    "ops:backup": "tsx -r dotenv/config scripts/ops/backup-json.ts",
    "ops:check-sheet": "tsx -r dotenv/config scripts/ops/check-sheet.ts",
    "ops:dryrun-import": "tsx -r dotenv/config scripts/ops/dryrun-import.ts",
    "crawler:sync": "tsx -r dotenv/config crawler/run.ts",
    "crawler:test": "tsx -r dotenv/config crawler/run.ts --test",
    "naver:test": "tsx -r dotenv/config crawler/naver/test.ts",
    "package:extract:test": "tsx crawler/core/packageExtractor.test.ts",
    "test:parsepackage": "tsx crawler/core/__tests__/parsePackage.test.ts",
    "test:oyanchor": "tsx crawler/core/__tests__/oliveyoungAnchor.test.ts",
    "shadow:title-parse": "tsx -r dotenv/config scripts/ops/title-parse-shadow.ts",
    "test:normalize": "tsx crawler/core/__tests__/normalize.test.ts",
    "test:healthcheck": "tsx crawler/core/__tests__/healthcheck.test.ts",
    "test:failcount": "tsx crawler/core/__tests__/failcount.test.ts",
    "test:prodguard": "tsx crawler/core/__tests__/prodguard.test.ts",
    "test:summary": "tsx crawler/core/__tests__/summary.test.ts",
    "test:publicprices": "tsx lib/queries/__tests__/publicPrices.test.ts",
    "test:weblayer": "tsx lib/queries/__tests__/webLayer.test.ts",
    "test:search": "tsx lib/__tests__/search.test.ts",
    "test:naver": "tsx crawler/adapters/__tests__/naver.test.ts",
    "test:navercrawl": "tsx crawler/core/__tests__/naverPageCrawl.test.ts",
    "test:coupang": "tsx crawler/adapters/__tests__/coupang.test.ts",
    "test:oliveyoung": "tsx crawler/adapters/__tests__/oliveyoung.test.ts",
    "test:sheets": "tsx crawler/sheets/__tests__/dedup.test.ts",
    "test:keymatch": "tsx crawler/sheets/__tests__/keymatch.test.ts",
    "test:schemav2": "tsx crawler/sheets/__tests__/schema_v2.test.ts",
    "test:inspection": "tsx crawler/sheets/__tests__/inspection.test.ts",
    "test:linkonly": "tsx crawler/sheets/__tests__/linkOnly.test.ts",
    "test:linkwriteback": "tsx crawler/sheets/__tests__/linkWriteback.test.ts",
    "test:imagekeep": "tsx crawler/sheets/__tests__/imageKeep.test.ts",
    "test:routenooffer": "tsx crawler/core/__tests__/routeNoOffer.test.ts",
    "test:waitlist": "tsx lib/__tests__/waitlist.test.ts",
    "test:all": "npm run test:normalize && npm run test:healthcheck && npm run test:failcount && npm run test:prodguard && npm run test:summary && npm run test:publicprices && npm run test:weblayer && npm run test:search && npm run test:naver && npm run test:navercrawl && npm run test:coupang && npm run test:oliveyoung && npm run package:extract:test && npm run test:parsepackage && npm run test:oyanchor && npm run test:sheets && npm run test:keymatch && npm run test:schemav2 && npm run test:inspection && npm run test:linkonly && npm run test:linkwriteback && npm run test:imagekeep && npm run test:routenooffer && npm run test:waitlist",
    "live-check:coupang": "tsx -r dotenv/config scripts/live-check/live-check-coupang.ts",
    "live-check:naver": "tsx -r dotenv/config scripts/live-check/live-check-naver.ts",
    "live-check:oliveyoung": "tsx -r dotenv/config scripts/live-check/live-check-oliveyoung.ts",
    "live-check:normalize": "tsx -r dotenv/config scripts/live-check/live-check-normalize.ts",
    "live-check:price-view": "tsx -r dotenv/config scripts/live-check/live-check-price-view.ts"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.108.1",
    "googleapis": "^173.0.0",
    "next": "16.2.9",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@opennextjs/cloudflare": "^1.19.11",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "dotenv": "^17.4.2",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "playwright": "^1.60.0",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5",
    "wrangler": "^4.100.0"
  }
}
