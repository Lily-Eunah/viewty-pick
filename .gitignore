# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# cloudflare / opennext (build output + local secrets)
/.open-next/
/.wrangler/
.dev.vars
.dev.vars.*
cloudflare-env.d.ts

# live-check artifacts & inferred ground-truth (network/key-dependent dumps;
# may contain affiliate tokens — keep out of git, regenerate locally)
/scripts/live-check/artifacts/
/scripts/live-check/expectations/

# ops data exports (DB dumps; URLs may carry affiliate tokens — regenerate locally)
/scripts/ops/exports/

# typescript
*.tsbuildinfo
next-env.d.ts

# DB backups (contain data, never commit)
backups/

# Claude agent logs, prompts, and temporary developer documents
.claude/
docs/prompts/
docs/reports/
docs/TBD.md
docs/blog/
viewtypick-resume-summary.md


# title-parse LLM 시험 캐시
.cache/

# scripts/ 하위의 임시 개발용 스크립트들 (앞에 _가 붙은 파일)
scripts/**/_*

# local OliveYoung crawl log (scheduled task)
oy-crawl.log
